class Solution {
    public int minimumCost(int[] cost) {
        Arrays.sort(cost);
        int ans = 0;
        int n = cost.length;
        int c = 1;
        for(int i = n - 1; i >= 0; i --) {
            if(c%3 != 0)
                ans+= cost[i];
            c++;
        }
        return ans;
    }
}