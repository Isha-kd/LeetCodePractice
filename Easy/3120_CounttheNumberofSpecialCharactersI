class Solution {
    public int numberOfSpecialChars(String s) {
        char[] arr = new char[26];
        int l = s.length();
        for(int i = 0; i < l; i ++) {
            if(s.charAt(i) > 96) arr[s.charAt(i)-'a'] = 1;
        }
        int ans = 0;
        for(int i = 0; i < l; i ++) {
            if(s.charAt(i) < 96 && arr[s.charAt(i)-'A'] == 1) {
                ans ++;
                arr[s.charAt(i)-'A'] = 0;
            }
        }
        return ans;
    }
}