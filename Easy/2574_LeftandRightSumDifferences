class Solution {
    public int[] leftRightDifference(int[] nums) {
        int tot = 0;
        for(int i : nums)
            tot += i;
        int n = nums.length;
        int[] ans = new int[n];
        int left = 0;
        for(int i = 0; i < n; i ++)  {
            tot -= nums[i];
            ans[i] = Math.abs(tot - left);
            left += nums[i];
        }
        return ans;
    }
}