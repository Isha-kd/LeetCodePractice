class Solution {
    public boolean judgeCircle(String moves) {
        int up = 0, right = 0;
        for(int i = 0; i < moves.length(); ++ i) {
            if(moves.charAt(i) == 'R')
                right++;
            else if(moves.charAt(i) == 'L')
                right--;
            else if(moves.charAt(i) == 'U')
                up++;
            else
                up--;
        }
        return up == 0 && right == 0;
    }
}