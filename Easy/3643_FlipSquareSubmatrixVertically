class Solution {
    public int[][] reverseSubmatrix(int[][] grid, int x, int y, int k) {
        int m=grid.length,n=grid[0].length;
        int[][] ans=new int[m][n];
        for(int i=0;i<m;i++) {
            for(int j=0;j<n;j++) {
                if(i>=x && i<x+k && j>=y && j<y+k) {
                    ans[i][j]=grid[k+x-1-(i-x)][j];
                }
                else ans[i][j]=grid[i][j];
            }
        }
        return ans;
    }
}