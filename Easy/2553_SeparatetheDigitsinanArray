class Solution {
    public int[] separateDigits(int[] nums) {
        StringBuilder sb = new StringBuilder();
        for(int i = nums.length-1; i >= 0; i--) {
            int x = nums[i];
            while(x > 0) {
                sb.append(x%10);
                x /= 10;
            }
        }
        int l = sb.length();
        int[] ans = new int[l];
        for(int i = 0; i < l; i ++) {
            ans[i] = sb.charAt(l - 1 - i) -'0';
        }
        return ans;
    }
}