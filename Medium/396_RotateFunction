class Solution {
    public int maxRotateFunction(int[] nums) {
        int n = nums.length;
        int tot = nums[0];
        int curr = 0;
        for(int i = 1; i < n; i ++) {
            tot += nums[i];
            curr += nums[i] * i;
        }

        int max = curr;

        for(int i = n-1; i >= 0; i--) {
            curr += tot;
            curr -= nums[i] * n;
            max = Math.max(max, curr);
        }

        return max;

    }
}