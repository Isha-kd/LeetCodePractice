class Solution {
    public String processStr(String s) {
        StringBuilder res = new StringBuilder();
        int l = s.length();
        for(int i = 0; i < l; i ++) {
            if(s.charAt(i) == '*') {
                if(res.length() > 0) res.deleteCharAt(res.length() - 1);
            } else if(s.charAt(i) == '#') res.append(res);
            else if(s.charAt(i) == '%') res.reverse();
            else res.append(s.charAt(i));
        }
        return res.toString();
    }
}