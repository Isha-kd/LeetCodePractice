class Solution {
    public int maxDistance(int[] nums1, int[] nums2) {
        int i = Math.min(nums1.length, nums2.length) -1, j = nums2.length - 1,ans = 0;
        while(i >= 0) {
            while(j >= i && nums2[j] < nums1[i]) {
                j --;
            }
            if(j >= 0 && nums2[j] >= nums1[i]) {
                ans = Math.max(ans,j - i);
            }
            i --;
        }
        return ans;
    }
}