class Solution {
    public double angleClock(int hour, int minutes) {
        double h, m;
        if(hour == 12) hour = 0;
        h = (hour * 60 + minutes)/2.0;
        m = minutes * 6;
        double diff = Math.max(h, m) - Math.min(h, m);
        if(diff > 180) return 360 - diff;
        return diff;
    }
}