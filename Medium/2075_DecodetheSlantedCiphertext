class Solution {
    public String decodeCiphertext(String encodedText, int rows) {
        int l = encodedText.length(), c = l / rows + 1;
        StringBuilder ans = new StringBuilder();
        for(int i = 0; i < c-1; ++ i) {
            for(int j = i; j < l; j += c) {
                ans.append(encodedText.charAt(j));
            }
        }
        return ans.toString().stripTrailing();
    }
}